{
  "name": "wolbolar/ipsymconastronomy",
  "description": "Astronomy module for IP-Symcon",
  "license": "GPL-3.0-or-later",
  "type": "project",
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.65"
  },
  "scripts": {
    "format": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --verbose",
    "format-check": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff --verbose",
    "lint": [
      "php -l Astronomy/module.php",
      "php -l bootstrap.php",
      "php -l libs/bootstrap.php",
      "php -l libs/ips.constants.php"
    ]
  },
  "config": {
    "platform": {
      "php": "8.2.0"
    },
    "sort-packages": true
  }
}
